import pandas as pd
from sqlalchemy import create_engine, text

supabase_url = 'postgresql://postgres.scdkwhbvaiekcusayetn:Brilha_mais@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require'
engine = create_engine(supabase_url)

with engine.connect() as conn:
    df_dups = pd.read_sql(text("SELECT nome_completo FROM tb_tecnico GROUP BY nome_completo HAVING COUNT(*) > 1"), conn)
    
    total_deletados = 0
    for nome in df_dups['nome_completo']:
        df_tecs = pd.read_sql(text("""
            SELECT id_tecnico, matricula 
            FROM tb_tecnico 
            WHERE nome_completo = :n 
            ORDER BY matricula DESC NULLS LAST, id_tecnico ASC
        """), conn, params={'n': nome})
        
        keep_id = int(df_tecs.iloc[0]['id_tecnico'])
        delete_ids = [int(x) for x in df_tecs.iloc[1:]['id_tecnico'].tolist()]
        
        if not delete_ids:
            continue
            
        print(f"[{nome}] Mantendo ID {keep_id} (Matrícula: {df_tecs.iloc[0]['matricula']}). Removendo IDs: {delete_ids}")
        
        # Migra chamados para o ID principal
        conn.execute(text("UPDATE tb_chamado SET id_tecnico = :keep WHERE id_tecnico = ANY(:dels)"), 
                     {'keep': keep_id, 'dels': delete_ids})
                     
        # Exclui apurações dos IDs fantasmas
        conn.execute(text("DELETE FROM tb_apuracao_mensal WHERE id_tecnico = ANY(:dels)"), 
                     {'dels': delete_ids})
                     
        # Exclui os técnicos duplicados
        conn.execute(text("DELETE FROM tb_tecnico WHERE id_tecnico = ANY(:dels)"), 
                     {'dels': delete_ids})
                     
        total_deletados += len(delete_ids)
        
    conn.commit()
    print(f"\\nSucesso! {total_deletados} registros duplicados de técnicos foram removidos.")
